# SkyWays Frontend – Environment Variables
# The React dev server proxies /api/v1/* to the backend gateway (package.json "proxy").
# For production, set REACT_APP_API_BASE_URL to your deployed gateway URL.

REACT_APP_NAME=SkyWays Airlines
REACT_APP_VERSION=1.0.0

# Override proxy target for production (leave blank to use package.json proxy)
# REACT_APP_API_BASE_URL=https://api.skyways.com

# Razorpay public key ID (safe to expose in frontend)
REACT_APP_RAZORPAY_KEY_ID=rzp_test_So35AlNQGIB4FP
